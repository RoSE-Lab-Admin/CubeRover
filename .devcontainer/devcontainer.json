{
  "name": "CubeRover Dev Container",
  "initializeCommand": "xhost +localhost || true", // For Mac users. It is expected that this command will not be found on Windows / Linux systems.
  // Build options
  // "build": { "dockerfile": "Dockerfile" }, // Build image locally
  "image": "docker.io/connorgro/cuberover-dev-jazzy:latest", // Use pre-built image
  "runArgs": [
    "--privileged",
    "--security-opt", "seccomp=unconfined", // Added for DDS/Hardware reliability
    "--net=host" // Use host network only on Linux/WSL (macOS ignores this)
  ],

  // ROS Settings
  "containerEnv": {
    // WSLg: Uses the local DISPLAY. Mac: Fallback to host.docker.internal
    "DISPLAY": "${localEnv:DISPLAY:-host.docker.internal:0}",
    "QT_X11_NO_MITSHM": "1", // Critical for GUI apps to not crash
    "HISTFILE": "/commandhistory/.bash_history" // Tells bash where to look
  },
  
  // Maintain bash command history between sessions
  "mounts": [
    "source=ros2-bash-history,target=/commandhistory,type=volume",
    // These mounts only work on WSL; Docker on Mac will ignore non-existent paths
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    // Allows the container to see the /dev folder where hardware lives
    "source=/dev,target=/dev,type=bind" 
  ],

  // VS Code customization settings
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "Ranch-Hand-Robotics.rde-pack",
        "redhat.vscode-xml"
      ],
      "settings": {
        // Performance optimizations to avoid hogging the CPU for parsing files
        "C_Cpp.workspaceParsingPriority": "low",
        "C_Cpp.indexing.maxConcurrentThreads": 1,
        "C_Cpp.exclusionPolicy": "checkFilesAndFolders",
        "C_Cpp.intelliSenseCacheSize": 512,
        "C_Cpp.default.browse.path": [ "${workspaceFolder}" ],
        "C_Cpp.default.browse.limitSymbolsToIncludedHeaders": true,

        // Prevent parsers from analysing ROS 2 build artifacts
        "files.watcherExclude": {
          "**/build/**": true, 
          "**/install/**": true, 
          "**/log/**": true, 
          "**/.git/**": true, 
          "**/.ros/**": true
        },
        "C_Cpp.files.exclude": {
          "**/build/**": true, 
          "**/install/**": true, 
          "**/log/**": true, 
          "**/.git/**": true, 
          "**/.ros/**": true
        },
        "python.analysis.exclude": [
          "**/build/**", 
          "**/install/**", 
          "**/log/**", 
          "**/.git/**", 
          "**/.ros/**"
        ],

        "python.defaultInterpreterPath": "/usr/bin/python3",
        "cmake.configureOnOpen": false,
        "search.followSymlinks": false
      }
    }
  },
  "remoteUser": "devuser",
  "postCreateCommand": "sudo apt-get update && rosdep install --from-paths src -y --ignore-src || true" // true to ensure no error if src empty
}
