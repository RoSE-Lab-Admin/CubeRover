<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="3" name="NavigateRecovery">

      <!-- Main pipeline sequence -->
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="0.5">
          <RecoveryNode number_of_retries="1" name="ComputePathRecovery">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            <ClearCostmapAroundRobot name="ClearGlobalCostmap-Context"
                        service_name="global_costmap/clear_around_global_costmap"
                        reset_distance="1.5"/>
          </RecoveryNode>
        </RateController>

        <RecoveryNode number_of_retries="1" name="FollowPathRecovery">
          <FollowPath path="{path}" controller_id="FollowPath"/>
          <ClearCostmapAroundRobot name="ClearLocalCostmap-Context"
                      service_name="local_costmap/clear_around_local_costmap"
                      reset_distance="1.0"/>
          <ClearCostmapAroundRobot name="ClearLocalCostmap-Context"
                      service_name="local_costmap/clear_around_local_costmap"
                      reset_distance="1.0"/>
        </RecoveryNode>

      </PipelineSequence>

      <!-- Recovery behaviors -->
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="RecoveryActions">
          <!-- First try, clear costmap and retry -->
          <!-- First try, clear costmap and retry -->
          <Sequence name="ClearingRecovery">
            <ClearCostmapAroundRobot name="ClearLocalCostmap-Recovery"
                                service_name="local_costmap/clear_around_local_costmap"
                                reset_distance="1.0"/>
            <ClearCostmapAroundRobot name="ClearGlobalCostmap-Recovery"
                                service_name="global_costmap/clear_around_global_costmap"
                                reset_distance="2.0"/>
            <ClearCostmapAroundRobot name="ClearLocalCostmap-Recovery"
                                service_name="local_costmap/clear_around_local_costmap"
                                reset_distance="1.0"/>
            <ClearCostmapAroundRobot name="ClearGlobalCostmap-Recovery"
                                service_name="global_costmap/clear_around_global_costmap"
                                reset_distance="2.0"/>
            <Wait wait_duration="2"/>
          </Sequence>
          <!-- Next try, back up -->
          <!-- Next try, back up -->
          <Sequence name="BackupRecovery">
            <BackUp backup_dist="0.10" backup_speed="-0.10"/>
            <Wait wait_duration="2"/>
          </Sequence>
          <!-- Next try, spin -->
          <Sequence name="SpinRecovery">
            <Spin spin_dist="0.262"/>
            <Wait wait_duration="2"/>
          </Sequence>
        </RoundRobin>
      </ReactiveFallback>

    </RecoveryNode>
  </BehaviorTree>
</root>
